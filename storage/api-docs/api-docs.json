{
    "openapi": "3.0.0",
    "info": {
        "title": "CRM Vật Liệu Xây Dựng API",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/",
            "description": "Local server"
        }
    ],
    "paths": {
        "/api/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Đăng nhập hệ thống",
                "description": "Login hệ thống",
                "operationId": "fd38eab35a3cc28d00ada587f6955506",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "example": "nguyenvana@gmail.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "nguyenvana123!"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Đăng nhập thành công",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "access_token": {
                                            "type": "string",
                                            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9"
                                        },
                                        "token_type": {
                                            "type": "string",
                                            "example": "bearer"
                                        },
                                        "expires_in": {
                                            "type": "integer",
                                            "example": 3600
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Sai email hoặc mật khẩu"
                    }
                }
            }
        },
        "/api/create-staff": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Admin tạo tài khoản nhân viên kho",
                "description": "Admin tạo tài khoản nhân viên kho",
                "operationId": "f91e12c6fa623c1142807255afd9a411",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "password",
                                    "password_confirmation"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Nhân viên kho 1"
                                    },
                                    "email": {
                                        "type": "string",
                                        "example": "staff@gmail.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "abc123!@#"
                                    },
                                    "password_confirmation": {
                                        "type": "string",
                                        "example": "abc123!@#"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Tạo tài khoản thành công",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Staff created"
                                        },
                                        "data": {
                                            "properties": {
                                                "id": {
                                                    "type": "integer",
                                                    "example": 2
                                                },
                                                "name": {
                                                    "type": "string",
                                                    "example": "Nhân viên kho 1"
                                                },
                                                "email": {
                                                    "type": "string",
                                                    "example": "staff@gmail.com"
                                                },
                                                "role": {
                                                    "type": "string",
                                                    "example": "warehouse_staff"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "403": {
                        "description": "Không có quyền"
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/staffs": {
            "get": {
                "tags": [
                    "Auth"
                ],
                "summary": "Lấy danh sách nhân viên kho",
                "description": "Lấy danh sách nhân viên kho",
                "operationId": "a119b5c192cd953728a93378f9279cf1",
                "responses": {
                    "200": {
                        "description": "Danh sách nhân viên kho",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "properties": {
                                            "id": {
                                                "type": "integer",
                                                "example": 2
                                            },
                                            "name": {
                                                "type": "string",
                                                "example": "Nhân viên kho 1"
                                            },
                                            "email": {
                                                "type": "string",
                                                "example": "staff@gmail.com"
                                            }
                                        },
                                        "type": "object"
                                    }
                                }
                            }
                        }
                    },
                    "403": {
                        "description": "Không có quyền"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/change-password": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Đổi mật khẩu",
                "description": "Đổi mật khẩu",
                "operationId": "bf2b1014a0ca6dcb68b1b36d11a2ce15",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "current_password",
                                    "password",
                                    "password_confirmation"
                                ],
                                "properties": {
                                    "current_password": {
                                        "type": "string",
                                        "example": "abc123!@#"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "newpassword123!"
                                    },
                                    "password_confirmation": {
                                        "type": "string",
                                        "example": "newpassword123!"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Đổi mật khẩu thành công",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Password changed"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Mật khẩu hiện tại không đúng"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Auth",
            "description": "API xác thực người dùng"
        }
    ]
}